<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ post.title }} - tldrop Summary</title>
    <style>
        :root {
            --bg: #fafafa;
            --fg: #1a1a1a;
            --accent: #0066cc;
            --muted: #666;
            --border: #ddd;
        }
        @media (prefers-color-scheme: dark) {
            :root {
                --bg: #1a1a1a;
                --fg: #e0e0e0;
                --accent: #66b3ff;
                --muted: #999;
                --border: #333;
            }
        }
        * { box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            line-height: 1.6;
            max-width: 800px;
            margin: 0 auto;
            padding: 2rem;
            background: var(--bg);
            color: var(--fg);
        }
        h1 {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            line-height: 1.3;
        }
        h2 {
            font-size: 1.2rem;
            margin-top: 2rem;
            border-bottom: 1px solid var(--border);
            padding-bottom: 0.3rem;
        }
        .meta {
            font-size: 0.9rem;
            color: var(--muted);
            margin-bottom: 1.5rem;
        }
        .meta a { color: var(--accent); }
        .tldr {
            background: var(--border);
            padding: 1rem;
            border-radius: 4px;
            margin: 1rem 0;
        }
        ul { padding-left: 1.5rem; }
        li { margin-bottom: 0.5rem; }
        .tags {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.5rem;
        }
        .tag {
            background: var(--accent);
            color: white;
            padding: 0.2rem 0.6rem;
            border-radius: 3px;
            font-size: 0.8rem;
        }
        footer {
            margin-top: 3rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border);
            font-size: 0.85rem;
            color: var(--muted);
        }
    </style>
</head>
<body>
    <article>
        <header>
            <h1>{{ post.title }}</h1>
            <div class="meta">
                <div>{{ post.published.strftime('%Y-%m-%d') }} · <a href="{{ post.url }}">Original post</a></div>
                {% if post.author %}<div>By {{ post.author }}</div>{% endif %}
                <div class="tags">
                    {% for topic in summary.topics_matched %}
                    <span class="tag">{{ topic }}</span>
                    {% endfor %}
                </div>
            </div>
        </header>

        <section>
            <h2>TL;DR</h2>
            <div class="tldr">{{ summary.tldr }}</div>
        </section>

        <section>
            <h2>Key Takeaways</h2>
            <ul>
                {% for takeaway in summary.key_takeaways %}
                <li>{{ takeaway }}</li>
                {% endfor %}
            </ul>
        </section>

        {% if summary.whats_new and summary.whats_new != 'N/A' %}
        <section>
            <h2>What's New</h2>
            <p>{{ summary.whats_new }}</p>
        </section>
        {% endif %}

        {% if summary.relevance %}
        <section>
            <h2>Relevance</h2>
            <p>{{ summary.relevance }}</p>
        </section>
        {% endif %}

        {% if summary.action_items %}
        <section>
            <h2>Action Items</h2>
            <ul>
                {% for item in summary.action_items %}
                <li>{{ item }}</li>
                {% endfor %}
            </ul>
        </section>
        {% endif %}
    </article>

    <footer>
        Generated by tldrop
    </footer>
</body>
</html>
