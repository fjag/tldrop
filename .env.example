# Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override default site (default: https://aws.amazon.com)
# TLDROP_SITE=https://aws.amazon.com

# Optional: Override default output directory (default: ./output)
# TLDROP_OUTPUT_DIR=./output

# Optional: Override default state directory (default: ./state)
# TLDROP_STATE_DIR=./state

# Optional: Override Claude models
# TLDROP_SUMMARIZER_MODEL=claude-sonnet-4-20250514
# TLDROP_FILTER_MODEL=claude-haiku-4-20250514
